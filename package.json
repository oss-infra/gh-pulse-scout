{
  "name": "gh-pulse-scout",
  "version": "0.1.0",
  "description": "Fetch recent GitHub issues for a repo and generate an AI-powered project status report.",
  "type": "module",
  "bin": {
    "gh-pulse-scout": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "github",
    "issues",
    "cli",
    "openai",
    "report",
    "analytics"
  ],
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "node-cache": "^5.1.2",
    "openai": "^4.67.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}