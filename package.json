{
  "name": "gh-pulse-scout",
  "version": "1.0.0",
  "description": "Fetch recent GitHub issues for a repo and generate an AI-powered project status report.",
  "type": "module",
  "bin": {
    "gh-pulse-scout": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "github",
    "issues",
    "cli",
    "openai",
    "report",
    "analytics"
  ],
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dayjs": "^1.11.21",
    "dotenv": "^16.6.1",
    "markdown-table": "^3.0.4",
    "node-cache": "^5.1.2",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}