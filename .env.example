# GitHub personal access token (repo scope for private repos, public_repo is enough for public)
GITHUB_TOKEN=ghp_xxx

# OpenAI-compatible API
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: when set to "1", upload the full issue-corpus file via the OpenAI
# Files API (purpose=assistants) and reference it in the prompt. Many
# OpenAI-compatible providers do not implement /files — failures are silently
# ignored and the inline corpus is still sent.
OPENAI_UPLOAD_CONTEXT=
